# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API
PORT=4000
NODE_ENV=development
# Comma-separated list of browser origins allowed by CORS.
# Production example:
# CORS_ALLOWED_ORIGINS=https://app.nodexpro.com,https://nodexpro.com,https://nodexpro.vercel.app
CORS_ALLOWED_ORIGINS=
# Set to true only if cookie-based cross-origin credentials are required.
# Current DocFlow portal uses token headers and does not require cookies.
CORS_ALLOW_CREDENTIALS=false

# Invitation emails (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=invites@mailer.nodexpro.com
APP_NAME=NodexPro
# Or: INVITE_FROM_EMAIL=NodexPro <noreply@yourdomain.com>

# App URL for invite links (used to build accept links)
# APP_URL=https://app.nodexpro.com
# Or: FRONTEND_URL=https://app.nodexpro.com

# Optional: JWT secret for custom verification (Supabase uses its own; service role for DB)
# API_KEY=optional-api-key

# AES-256-GCM for client tax payment card blobs (backend only; required to save/reveal card data).
# Format: standard base64 (no quotes) decoding to EXACTLY 32 raw bytes — typically 43–44 characters when encoded.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set only in apps/api/.env (never commit real keys; never expose to frontend).
CLIENT_DATA_ENCRYPTION_KEY=

# Payment-card SMS OTP (production). If unset, API logs OTP to console (dev only — configure Twilio for prod).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+972XXXXXXXXX
# Optional separate pepper for OTP hashing (defaults to CLIENT_DATA_ENCRYPTION_KEY material)
# SENSITIVE_ACCESS_CODE_PEPPER=

# Platform owner — один email на всю платформу (только /api/v1/owner/* и Owner Panel).
# Не используйте этот же email как обычный пользователь организации — заведите отдельный логин для офиса.
PLATFORM_OWNER_EMAIL=marinator.321@gmail.com
# Israel mobile (для SMS OTP сброса пароля владельца; нормализация в E.164 +972…)
# PLATFORM_OWNER_PHONE=0544678275
# Optional legacy hashes (if used by your deployment):
# PLATFORM_OWNER_PASSWORD_HASH=
# PLATFORM_OWNER_ACCESS_KEY_HASH=
